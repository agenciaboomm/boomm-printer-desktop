# URL base da API SaaS Boomm Printer
SAAS_API_URL=https://sua-instancia.base44.com

# Chave de API (preenchida via interface do app)
SAAS_API_KEY=

# Nome do computador (default: hostname do sistema)
COMPUTER_NAME=

# Intervalo de polling em milissegundos (default: 5000)
POLLING_INTERVAL=5000

# Ambiente
NODE_ENV=development
